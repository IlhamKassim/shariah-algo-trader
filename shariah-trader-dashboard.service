[Unit]
Description=Shariah Algo Trader Dashboard
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/shariah-algo-trader
EnvironmentFile=/home/ubuntu/shariah-algo-trader/.env
ExecStart=/home/ubuntu/shariah-algo-trader/.venv/bin/uvicorn dashboard.api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
